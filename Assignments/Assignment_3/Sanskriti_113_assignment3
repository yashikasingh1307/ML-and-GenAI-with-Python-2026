    "#func to reverse a number\n",
    "def reverse_number(num):\n",
    "    rev = 0\n",
    "\n",
    "    while num > 0:\n",
    "        digit = num % 10\n",
    "        rev = rev * 10 + digit\n",
    "        num = num // 10\n",
    "\n",
    "    return rev\n",
    "\n",
    "print(reverse_number(5678))"
   ]
