    "# calculator\n",
    "def calculator(a, b, op):\n",
    "    if op == '+':\n",
    "        return a + b\n",
    "    elif op == '-':\n",
    "        return a - b\n",
    "    elif op == '*':\n",
    "        return a * b\n",
    "    elif op == '/':\n",
    "        if b == 0:\n",
    "            return \"Cannot divide by zero\"\n",
    "        return a / b\n",
    "    else:\n",
    "        return \"Invalid operator\"\n",
    "\n",
    "\n",
    "def main():\n",
    "    print(\"Operations: +  -  *  /\")\n",
    "    \n",
    "    a = float(input(\"Enter first number: \"))\n",
    "    op = input(\"Enter operation: \")\n",
    "    b = float(input(\"Enter second number: \"))\n",
    "\n",
    "    result = calculator(a, b, op)\n",
    "    print(\"Result =\", result)\n",
    "\n",
    "\n",
    "main()\n"
   ]
